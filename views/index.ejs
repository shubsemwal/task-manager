<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
<div class="main w-full min-h-screen bg-[#18181b]">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Notes App</title>

<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-gray-100 dark:bg-zinc-900 transition duration-300">

<!-- NAVBAR -->

<div class="flex justify-between items-center px-10 py-5 bg-white dark:bg-zinc-800 shadow">

<h1 class="text-3xl font-bold text-gray-800 dark:text-white">
📝 Notes App
</h1>

<button onclick="toggleDark()" 
class="px-4 py-2 bg-black text-white dark:bg-white dark:text-black rounded-lg">
Toggle Mode
</button>

</div>


<!-- MAIN CONTAINER -->

<div class="max-w-6xl mx-auto">

<!-- FORM -->

<div class="p-10">

<form action="/create" method="POST" 
class="bg-[#2d3748] dark:bg-zinc-800 shadow-lg rounded-xl p-6 space-y-4 text-white">

<h2 class="text-xl font-semibold text-white-700 dark:text-white">
Create Task
</h2>

<input
class="w-full p-3 rounded-lg border focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-zinc-700 dark:text-white"
type="text"
name="title"
placeholder="Title..."
required
/>

<textarea
class=" w-full p-3 rounded-lg border resize-none focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-zinc-700 dark:text-white"
name="description"
placeholder="Description..."
></textarea>

<button
class="bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-lg transition">
Create Task
</button>

</form>

</div>


<!-- TASK LIST -->

<div class="p-10 grid md:grid-cols-3 gap-6">

<% if(files && files.length > 0){ %>

<% files.forEach(function(file){ %>

<div class="bg-[#2d3748] dark:bg-zinc-800 rounded-xl shadow-md p-6 hover:shadow-xl transition">

<h2 class="text-xl font-semibold text-white dark:text-white mb-4">
<%= file %>
</h2>

<div class="flex gap-4 text-sm">

<a href="/file/<%= file %>"
class="text-blue-500 hover:underline">
Read
</a>

<a href="/edit/<%= file %>"
class="text-yellow-500 hover:underline">
Edit
</a>

<a href="/delete/<%= file %>"
onclick="return confirmDelete()"
class="text-red-500 hover:underline">
Delete
</a>

</div>

</div>

<% }) %>

<% } else { %>

<p class="text-gray-500 dark:text-gray-400">
No tasks yet
</p>

<% } %>

</div>

</div>


<!-- JAVASCRIPT -->

<script>

function toggleDark(){
document.documentElement.classList.toggle("dark");
}

function confirmDelete(){
return confirm("Are you sure you want to delete this task?");
}

</script>

</body>
</html>
    
</div>
</body>
</html>