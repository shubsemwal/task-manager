<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
<div class="main w-full min-h-screen bg-zinc-200">
    <div class="form p-10">
       <form action="/create"method="POST">
        <input class="block p-2 w-full rounded-md bg-zinc-500 text-white" type="text" name="title" placeholder="title..">
        <textarea class="block p-2 w-full rounded-md mt-2 resize-none bg-zinc-500 text-white " name="description" placeholder="description........." id=""></textarea>
        <input class="block p-2 mt-2 bg-green-500 rounded-md" type="submit" placeholder="create task">

       </form>
    </div>
    <div class="tasks flex gap-3 flex-wrap p-10">
        <%if (files.length > 0) { %>
            <% files.forEach(function(file) { %>

                <div class="task min-w-72 py-4 px-3 rounded-md bg-zinc-500">
                    <h1 class="text-white text-3xl tracking-tighter"><%= file %></h1>
                    <p> Lorem ipsum dolor sit amet consectetur adipisicing elit. Cum possimus nam commodi.</p>
                    <!-- <a class="text-blue-800" href="">Read more</a> -->
                </div>
    
                <%}) %>
            <%}else { %>
               <h3 class="text-zinc-500">No tasks yet.</h3>
                <%} %>
    </div>
    
</div>
</body>
</html>